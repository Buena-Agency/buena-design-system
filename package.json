{
  "name": "@buena/brand",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "main": "./dist/lib/index.js",
  "module": "./dist/lib/index.js",
  "types": "./dist/lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/lib/index.d.ts",
      "import": "./dist/lib/index.js"
    },
    "./tokens": {
      "types": "./dist/lib/tokens/index.d.ts",
      "import": "./dist/lib/tokens.js"
    },
    "./icons": {
      "types": "./dist/lib/icons/index.d.ts",
      "import": "./dist/lib/icons.js"
    },
    "./components": {
      "types": "./dist/lib/components/index.d.ts",
      "import": "./dist/lib/components.js"
    },
    "./tailwind": {
      "types": "./dist/lib/tailwind/preset.d.ts",
      "import": "./dist/lib/tailwind.js"
    },
    "./styles.css": "./dist/lib/brand.css",
    "./components.css": "./dist/lib/components.css",
    "./stylelint": "./stylelint-config.json"
  },
  "files": [
    "dist/lib",
    "stylelint-config.json"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:lib": "vite build --config vite.lib.config.ts && tsc -p tsconfig.lib.json",
    "prepare": "vite build --config vite.lib.config.ts && tsc -p tsconfig.lib.json",
    "typecheck": "tsc -b"
  },
  "peerDependencies": {
    "react": "^18.3.1 || ^19.0.0",
    "react-dom": "^18.3.1 || ^19.0.0"
  },
  "devDependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/modifiers": "^7.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "clsx": "^2.1.1",
    "postcss": "^8.4.39",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.5.3",
    "vite": "^5.3.4"
  }
}
